# Champion Trader — environment template. Copy to `.env` and fill in.
# Every key the backend reads is listed here; values shown are the in-code
# defaults (backend/config.py) unless marked REQUIRED. Secrets are placeholders.
# `.env` is git-ignored.

# --- Database -----------------------------------------------------------------
DATABASE_URL=sqlite:///./champion_trader.db
# DATABASE_URL=postgresql://user:password@localhost/champion_trader

# --- Telegram (entry/exit fill + risk alerts; safe no-op if unset) ------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- Zerodha Kite Connect (broker = Kite; feed AND execution) -----------------
# The bar store and the Phase-2 execution client both use Kite. KITE_ACCESS_TOKEN
# is session-bound: refresh it daily via `python scripts/kite_login.py` (RUNBOOK).
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=your_daily_kite_access_token

# --- TradingView webhook ------------------------------------------------------
WEBHOOK_SECRET=your_secret_key_here

# --- CORS (comma-separated origins allowed to call the API) -------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- App ----------------------------------------------------------------------
APP_PORT=8000
ENVIRONMENT=development

# --- Bar store (Kite-adjusted daily OHLCV) ------------------------------------
# The SAME feed the backtest reads, so live v2 scan/entry/exit stay parity-faithful.
# Written by `scripts/ingest_kite_daily.py`; git-ignored (~231MB).
BARS_DB_PATH=./champion_cache.sqlite

# --- Paper engine -------------------------------------------------------------
# Virtual account the validated v2 strategy trades until go-live. Rs 10,00,000 over
# the full universe gives non-degenerate sizing (Rs 1L rounds expensive names to 0).
PAPER_CAPITAL=1000000

# --- Position-sizing defaults (manual calculator only) ------------------------
# NOTE: the v2 engine's risk overlay (RPT 0.35 / max-15 / bear-0.25x / 15%-DD halt)
# lives in backend/engine/runtime/config.py, NOT here. These are the manual
# calculator's defaults only.
DEFAULT_ACCOUNT_VALUE=1000000
DEFAULT_RPT_PCT=0.50
DEFAULT_EXCHANGE=NSE

# --- Anthropic (CIO Agent daily brief) ----------------------------------------
ANTHROPIC_API_KEY=your_key_here

# --- AutoOptimize — FROZEN for the v2 rollout (do NOT enable) ------------------
# Overnight auto-tuning must not perturb the validated, parity-gated params.
AUTOOPTIMIZE_ENABLED=false
AUTOOPTIMIZE_START_HOUR=18
AUTOOPTIMIZE_HALT_HOUR=8
AUTOOPTIMIZE_MODEL=claude-sonnet-4-5

# --- RAG ----------------------------------------------------------------------
RAG_PERSIST_DIR=./rag/chromadb
CORPUS_B_RETENTION_DAYS=90

# --- Broker — real orders stay gated until a clean paper run ------------------
# BROKER_LIVE_TRADING is the kill-switch (keep false); BROKER_TYPE: paper | jhaveri.
BROKER_LIVE_TRADING=false
BROKER_TYPE=paper

# --- Research / data-build (optional) -----------------------------------------
# Only needed to rebuild the Atlas/Supabase corpus (scripts/build_cache.py,
# scripts/build_index_cache.py). The app ignores unknown keys, so leave blank
# unless you are rebuilding the cache.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Frontend (set in frontend/.env.local, not here) --------------------------
# The Next.js app reads NEXT_PUBLIC_API_URL at build/runtime; defaults to
# http://localhost:8000 when unset.
# NEXT_PUBLIC_API_URL=http://localhost:8000
