# Database
DATABASE_URL=sqlite:///./champion_trader.db
# DATABASE_URL=postgresql://user:password@localhost/champion_trader

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Dhan Broker API
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token

# TradingView Webhook (for incoming alerts)
WEBHOOK_SECRET=your_secret_key_here

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# App settings
APP_PORT=8000
ENVIRONMENT=development

# Defaults (can be overridden in app)
DEFAULT_ACCOUNT_VALUE=1000000
DEFAULT_RPT_PCT=0.50
DEFAULT_EXCHANGE=NSE

# Anthropic (CIO Agent + AutoOptimize)
ANTHROPIC_API_KEY=your_key_here

# AutoOptimize
AUTOOPTIMIZE_ENABLED=true
AUTOOPTIMIZE_START_HOUR=18
AUTOOPTIMIZE_HALT_HOUR=8
AUTOOPTIMIZE_MODEL=claude-sonnet-4-5

# RAG
RAG_PERSIST_DIR=./rag/chromadb
CORPUS_B_RETENTION_DAYS=90

# Broker
BROKER_LIVE_TRADING=false
BROKER_TYPE=paper
