// =============================================================================
// CTS - True Range Percentage (TRP) Indicator
// Champion Trader System by Jhaveri Securities
// =============================================================================
// TRP measures the percentage range of each candle relative to its close price.
// It quantifies volatility in percentage terms, making it comparable across
// different price levels and instruments. A higher TRP means the stock is
// "moving enough" to be worth trading. Stocks with TRP consistently below 2%
// are typically too slow for active swing trading.
// =============================================================================

//@version=5
indicator("CTS - TRP Indicator", overlay=false, precision=2)

// ---------------------------------------------------------------------------
// INPUT PARAMETERS
// ---------------------------------------------------------------------------

// Period for the TRP simple moving average — 20 bars captures roughly one
// trading month of data, smoothing out day-to-day noise
trp_period = input.int(20, "TRP Average Period", minval=5, maxval=100,
    tooltip="Number of bars for TRP moving average. 20 is roughly one trading month.")

// The minimum TRP value we consider "tradeable" — below this, the stock
// doesn't move enough intraday to generate meaningful swing profits
tradeable_threshold = input.float(2.0, "Tradeable TRP Threshold (%)", minval=0.5, maxval=5.0, step=0.1,
    tooltip="Minimum TRP% to consider a stock tradeable. Below this, moves are too small.")

// Alert fires when current TRP exceeds average by this multiple — signals
// unusual expansion that often precedes a sustained directional move
alert_threshold = input.float(2.5, "Alert Threshold (x avg TRP)", minval=1.5, maxval=5.0, step=0.1,
    tooltip="Alert triggers when TRP exceeds this multiple of average TRP.")

// Visual preferences
show_table = input.bool(true, "Show Info Table", tooltip="Display the TRP metrics table on chart.")
table_position = input.string("top_right", "Table Position",
    options=["top_right", "top_left", "bottom_right", "bottom_left"])

// ---------------------------------------------------------------------------
// TRP CALCULATION
// ---------------------------------------------------------------------------

// True Range Percentage = candle range as a percentage of closing price.
// Using close (not open) because close represents where the market settled
// and is the reference point for next-day trading decisions.
candle_range = high - low
trp = (candle_range / close) * 100

// Simple moving average of TRP over the lookback period — this is the
// "normal" volatility baseline for the stock
avg_trp = ta.sma(trp, trp_period)

// TRP Ratio tells us how the current bar's volatility compares to the norm.
// Ratio > 1.0 means wider than usual, < 1.0 means tighter than usual.
// Ratios above 2.0-2.5 often signal pivotal candles or breakout bars.
trp_ratio = avg_trp > 0 ? trp / avg_trp : 0.0

// ---------------------------------------------------------------------------
// COLOR LOGIC
// ---------------------------------------------------------------------------

// Green when TRP is above the tradeable threshold — the stock is moving enough.
// Red when below — too tight, not worth active trading.
trp_color = trp >= tradeable_threshold ? color.new(color.green, 0) : color.new(color.red, 0)

// Average line gets a brighter color when above threshold, dimmer when below
avg_color = avg_trp >= tradeable_threshold ? color.new(color.teal, 20) : color.new(color.gray, 40)

// Background highlight when TRP ratio exceeds the alert threshold — makes
// unusual volatility bars immediately visible on the chart
is_unusual_volatility = trp_ratio >= alert_threshold
bg_color = is_unusual_volatility ? color.new(color.yellow, 85) : na

// ---------------------------------------------------------------------------
// PLOTTING
// ---------------------------------------------------------------------------

// Main TRP line — shows bar-by-bar volatility percentage
plot(trp, "TRP", color=trp_color, linewidth=2, style=plot.style_histogram)

// Average TRP line — the baseline for comparison
plot(avg_trp, "Avg TRP", color=avg_color, linewidth=2, style=plot.style_line)

// Tradeable threshold reference line — anything above this is "in play"
hline(tradeable_threshold, "Tradeable Threshold", color=color.new(color.white, 60), linestyle=hline.style_dashed)

// Zero reference
hline(0, "Zero", color=color.new(color.gray, 80))

// Background highlight for unusual volatility bars
bgcolor(bg_color, title="Unusual Volatility Highlight")

// ---------------------------------------------------------------------------
// INFO TABLE
// ---------------------------------------------------------------------------

if show_table and barstate.islast
    // Determine table position
    tbl_pos = switch table_position
        "top_right"    => position.top_right
        "top_left"     => position.top_left
        "bottom_right" => position.bottom_right
        "bottom_left"  => position.bottom_left
        => position.top_right

    var tbl = table.new(tbl_pos, 2, 5,
        bgcolor=color.new(color.black, 10),
        border_color=color.new(color.gray, 60),
        border_width=1)

    // Header
    table.cell(tbl, 0, 0, "TRP Metrics", text_color=color.white, text_size=size.small,
        bgcolor=color.new(color.teal, 20))
    table.cell(tbl, 1, 0, syminfo.tickerid, text_color=color.white, text_size=size.small,
        bgcolor=color.new(color.teal, 20))

    // Current TRP
    trp_display_color = trp >= tradeable_threshold ? color.green : color.red
    table.cell(tbl, 0, 1, "Current TRP", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(trp, "#.##") + "%", text_color=trp_display_color, text_size=size.small)

    // Average TRP
    avg_display_color = avg_trp >= tradeable_threshold ? color.teal : color.gray
    table.cell(tbl, 0, 2, "Avg TRP (" + str.tostring(trp_period) + ")", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(avg_trp, "#.##") + "%", text_color=avg_display_color, text_size=size.small)

    // TRP Ratio
    ratio_color = trp_ratio >= alert_threshold ? color.yellow : trp_ratio >= 1.5 ? color.orange : color.white
    table.cell(tbl, 0, 3, "TRP Ratio", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 3, str.tostring(trp_ratio, "#.##") + "x", text_color=ratio_color, text_size=size.small)

    // Tradeable status
    status_text = trp >= tradeable_threshold ? "TRADEABLE" : "TOO TIGHT"
    status_color = trp >= tradeable_threshold ? color.green : color.red
    table.cell(tbl, 0, 4, "Status", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 4, status_text, text_color=status_color, text_size=size.small)

// ---------------------------------------------------------------------------
// ALERT CONDITIONS
// ---------------------------------------------------------------------------

// Fires when current bar's TRP exceeds the average by the alert threshold
// multiplier. This often signals the beginning of a significant move — either
// a breakout, a reversal, or a gap event.
alertcondition(is_unusual_volatility,
    title="Unusual Volatility",
    message='{"symbol": "{{ticker}}", "alert_type": "UNUSUAL_VOLATILITY", "price": {{close}}, "close": {{close}}, "trp": ' + str.tostring(trp, "#.##") + ', "avg_trp": ' + str.tostring(avg_trp, "#.##") + ', "trp_ratio": ' + str.tostring(trp_ratio, "#.##") + '}')

// Fires when TRP crosses above the tradeable threshold — stock is waking up
alertcondition(ta.crossover(trp, tradeable_threshold),
    title="TRP Becomes Tradeable",
    message='{"symbol": "{{ticker}}", "alert_type": "TRP_TRADEABLE", "price": {{close}}, "close": {{close}}, "trp": ' + str.tostring(trp, "#.##") + '}')

// Fires when average TRP crosses above threshold — sustained increase in
// volatility, not just a single bar spike
alertcondition(ta.crossover(avg_trp, tradeable_threshold),
    title="Avg TRP Becomes Tradeable",
    message='{"symbol": "{{ticker}}", "alert_type": "AVG_TRP_TRADEABLE", "price": {{close}}, "close": {{close}}, "avg_trp": ' + str.tostring(avg_trp, "#.##") + '}')
