// =============================================================================
// CTS - Negative Pivotal Candle (NPC) Scanner
// Champion Trader System by Jhaveri Securities
// =============================================================================
// A Negative Pivotal Candle signals strong institutional selling pressure.
// It is the bearish mirror of the PPC — unusual range expansion combined with
// a weak close position, above-average volume, and a red candle. NPCs often
// mark the beginning of significant downward moves, distribution phases, or
// the end of a Stage 2 advance.
//
// ALL four conditions must be true simultaneously:
//   1. TRP >= 1.5x average TRP (range expansion — shock event)
//   2. Close in lower 40% of range (bears won the session)
//   3. Volume >= 1.5x 20-day avg volume (heavy selling participation)
//   4. Close < Open (red candle — net selling pressure)
// =============================================================================

//@version=5
indicator("CTS - NPC Scanner", overlay=true, max_labels_count=500, max_bars_back=500)

// ---------------------------------------------------------------------------
// INPUT PARAMETERS
// ---------------------------------------------------------------------------

// TRP calculation period — matches TRP Indicator and PPC Scanner for consistency
trp_period = input.int(20, "TRP Average Period", minval=5, maxval=100,
    tooltip="Period for calculating average TRP. Keep consistent across CTS scripts.")

// Volume average period
vol_period = input.int(20, "Volume Average Period", minval=5, maxval=100,
    tooltip="Period for calculating average volume.")

// Minimum TRP ratio — candle must be 50%+ wider than normal to qualify
min_trp_ratio = input.float(1.5, "Min TRP Ratio", minval=1.0, maxval=5.0, step=0.1,
    tooltip="Minimum TRP/Avg TRP ratio for NPC detection.")

// Strong NPC threshold — exceptional selling events
strong_trp_ratio = input.float(2.5, "Strong NPC TRP Ratio", minval=2.0, maxval=5.0, step=0.1,
    tooltip="TRP ratio above this marks a Strong NPC (panic selling).")

// Maximum close position — must close in the lower portion of the range.
// 0.40 means close must be in the bottom 40% of the candle.
max_close_position = input.float(0.40, "Max Close Position", minval=0.10, maxval=0.50, step=0.05,
    tooltip="Close must be at or below this percentile of bar range. 0.40 = lower 40%.")

// Minimum volume ratio — selling on high volume confirms distribution
min_vol_ratio = input.float(1.5, "Min Volume Ratio", minval=1.0, maxval=5.0, step=0.1,
    tooltip="Volume must exceed average by this multiple.")

// Lookback window for NPC count
lookback_bars = input.int(60, "Lookback Bars for Count", minval=10, maxval=200,
    tooltip="Count NPCs within this many recent bars.")

// Visual settings
show_labels = input.bool(true, "Show NPC Labels", tooltip="Display labels below NPC candles.")
show_table = input.bool(true, "Show Info Table", tooltip="Display NPC metrics table.")
table_position = input.string("top_right", "Table Position",
    options=["top_right", "top_left", "bottom_right", "bottom_left"])

// ---------------------------------------------------------------------------
// CORE CALCULATIONS
// ---------------------------------------------------------------------------

// TRP — True Range Percentage for each bar
candle_range = high - low
trp = candle_range / close * 100
avg_trp = ta.sma(trp, trp_period)

// TRP ratio — how this bar compares to normal volatility
trp_ratio = avg_trp > 0 ? trp / avg_trp : 0.0

// Close position within the candle range (0 = closed at low, 1 = closed at high)
// For NPC, we want this value to be LOW — close near the bottom of the bar
close_position = candle_range > 0 ? (close - low) / candle_range : 0.5

// Volume analysis
avg_volume = ta.sma(volume, vol_period)
vol_ratio = avg_volume > 0 ? volume / avg_volume : 0.0

// ---------------------------------------------------------------------------
// NPC DETECTION LOGIC
// ---------------------------------------------------------------------------

// Condition 1: Range expansion — the candle is significantly wider than normal.
// Wide-range bearish bars mean the stock dropped hard, often on news or
// institutional distribution.
condition_trp = trp_ratio >= min_trp_ratio

// Condition 2: Weak close position — the bears controlled the session.
// Even if the bar opened high, it closed near the low, showing selling
// pressure dominated. This is the key differentiator from a PPC.
condition_close = close_position <= max_close_position

// Condition 3: Above-average volume — the selling has conviction. Wide-range
// bars on low volume could be illiquidity, not real distribution.
condition_volume = vol_ratio >= min_vol_ratio

// Condition 4: Red candle — net selling. Close below open confirms
// the bearish bias for the session.
condition_bearish = close < open

// ALL four conditions must be true simultaneously
is_npc = condition_trp and condition_close and condition_volume and condition_bearish

// Classify NPC strength — strong NPCs indicate panic or forced selling
is_strong_npc = is_npc and trp_ratio >= strong_trp_ratio
is_standard_npc = is_npc and trp_ratio < strong_trp_ratio

// ---------------------------------------------------------------------------
// NPC COUNT OVER LOOKBACK PERIOD
// ---------------------------------------------------------------------------

// Count how many NPCs occurred in the recent lookback window.
// Multiple NPCs in a short period signal sustained distribution —
// institutions are actively exiting the stock.
npc_count = 0
for i = 0 to lookback_bars - 1
    candle_range_i = high[i] - low[i]
    trp_i = candle_range_i / close[i] * 100
    avg_trp_i = ta.sma(trp, trp_period)[i]
    trp_ratio_i = avg_trp_i > 0 ? trp_i / avg_trp_i : 0.0
    close_pos_i = candle_range_i > 0 ? (close[i] - low[i]) / candle_range_i : 0.5
    avg_vol_i = ta.sma(volume, vol_period)[i]
    vol_ratio_i = avg_vol_i > 0 ? volume[i] / avg_vol_i : 0.0
    if trp_ratio_i >= min_trp_ratio and close_pos_i <= max_close_position and vol_ratio_i >= min_vol_ratio and close[i] < open[i]
        npc_count += 1

// ---------------------------------------------------------------------------
// VISUAL PLOTTING
// ---------------------------------------------------------------------------

// Paint NPC candles with distinct red colors so they stand out.
// Strong NPCs get a brighter, more saturated red.
barcolor(is_strong_npc ? color.new(color.fuchsia, 0) : is_standard_npc ? color.new(color.red, 10) : na,
    title="NPC Bar Color")

// Background flash on NPC bars — a warning signal on the chart
bgcolor(is_strong_npc ? color.new(color.fuchsia, 90) : is_standard_npc ? color.new(color.red, 92) : na,
    title="NPC Background")

// Label below NPC candles showing strength classification
if show_labels and is_strong_npc
    label.new(bar_index, low, "STRONG\nNPC",
        style=label.style_label_up,
        color=color.new(color.fuchsia, 10),
        textcolor=color.white,
        size=size.small)
else if show_labels and is_standard_npc
    label.new(bar_index, low, "NPC",
        style=label.style_label_up,
        color=color.new(color.red, 20),
        textcolor=color.white,
        size=size.tiny)

// ---------------------------------------------------------------------------
// SHAPE MARKERS for screener compatibility
// ---------------------------------------------------------------------------

// plotshape works with TradingView screener; labels do not
plotshape(is_strong_npc, title="Strong NPC Marker", location=location.belowbar,
    style=shape.diamond, color=color.fuchsia, size=size.small)
plotshape(is_standard_npc, title="Standard NPC Marker", location=location.belowbar,
    style=shape.triangledown, color=color.red, size=size.tiny)

// ---------------------------------------------------------------------------
// INFO TABLE
// ---------------------------------------------------------------------------

if show_table and barstate.islast
    tbl_pos = switch table_position
        "top_right"    => position.top_right
        "top_left"     => position.top_left
        "bottom_right" => position.bottom_right
        "bottom_left"  => position.bottom_left
        => position.top_right

    var tbl = table.new(tbl_pos, 2, 7,
        bgcolor=color.new(color.black, 10),
        border_color=color.new(color.gray, 60),
        border_width=1)

    // Header
    table.cell(tbl, 0, 0, "NPC Scanner", text_color=color.white, text_size=size.small,
        bgcolor=color.new(color.red, 30))
    table.cell(tbl, 1, 0, syminfo.tickerid, text_color=color.white, text_size=size.small,
        bgcolor=color.new(color.red, 30))

    // Current TRP
    table.cell(tbl, 0, 1, "TRP", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(trp, "#.##") + "%", text_color=color.white, text_size=size.small)

    // TRP Ratio
    ratio_color = trp_ratio >= strong_trp_ratio ? color.fuchsia : trp_ratio >= min_trp_ratio ? color.red : color.gray
    table.cell(tbl, 0, 2, "TRP Ratio", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(trp_ratio, "#.##") + "x", text_color=ratio_color, text_size=size.small)

    // Close Position — lower is more bearish for NPC
    cp_color = close_position <= max_close_position ? color.red : color.green
    table.cell(tbl, 0, 3, "Close Pos", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 3, str.tostring(close_position * 100, "#.#") + "%", text_color=cp_color, text_size=size.small)

    // Volume Ratio
    vr_color = vol_ratio >= min_vol_ratio ? color.red : color.gray
    table.cell(tbl, 0, 4, "Vol Ratio", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 4, str.tostring(vol_ratio, "#.##") + "x", text_color=vr_color, text_size=size.small)

    // NPC Count in lookback
    count_color = npc_count >= 3 ? color.fuchsia : npc_count >= 1 ? color.red : color.gray
    table.cell(tbl, 0, 5, "NPCs (" + str.tostring(lookback_bars) + " bars)", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 5, str.tostring(npc_count), text_color=count_color, text_size=size.small)

    // Current bar NPC status
    npc_status = is_strong_npc ? "STRONG NPC" : is_standard_npc ? "NPC" : "---"
    npc_status_color = is_strong_npc ? color.fuchsia : is_standard_npc ? color.red : color.gray
    table.cell(tbl, 0, 6, "Current Bar", text_color=color.gray, text_size=size.small)
    table.cell(tbl, 1, 6, npc_status, text_color=npc_status_color, text_size=size.small)

// ---------------------------------------------------------------------------
// ALERT CONDITIONS
// ---------------------------------------------------------------------------

// Webhook JSON messages for backend integration
npc_alert_message = '{"symbol": "{{ticker}}", "alert_type": "NPC_DETECTED", "price": {{close}}, "close": {{close}}, "volume": {{volume}}, "trp": ' + str.tostring(trp, "#.##") + ', "trp_ratio": ' + str.tostring(trp_ratio, "#.##") + ', "volume_ratio": ' + str.tostring(vol_ratio, "#.##") + ', "close_position": ' + str.tostring(close_position, "#.###") + '}'

strong_npc_alert_message = '{"symbol": "{{ticker}}", "alert_type": "STRONG_NPC_DETECTED", "price": {{close}}, "close": {{close}}, "volume": {{volume}}, "trp": ' + str.tostring(trp, "#.##") + ', "trp_ratio": ' + str.tostring(trp_ratio, "#.##") + ', "volume_ratio": ' + str.tostring(vol_ratio, "#.##") + ', "close_position": ' + str.tostring(close_position, "#.###") + '}'

// Alert for any NPC detection (standard or strong)
alertcondition(is_npc,
    title="NPC Detected",
    message=npc_alert_message)

// Separate alert for strong NPCs — these are panic/capitulation signals
alertcondition(is_strong_npc,
    title="Strong NPC Detected",
    message=strong_npc_alert_message)

// Alert when multiple NPCs cluster — distribution is accelerating
alertcondition(npc_count >= 3,
    title="NPC Cluster Warning",
    message='{"symbol": "{{ticker}}", "alert_type": "NPC_CLUSTER", "price": {{close}}, "close": {{close}}, "npc_count": ' + str.tostring(npc_count) + '}')
